
@misc{fang_computational_2026,
	title = {Computational Structure of Egocentric Boundary Cell Responses in Retrosplenial Cortex},
	url = {https://www.ssrn.com/abstract=6427258},
	doi = {10.2139/ssrn.6427258},
	abstract = {Spatial navigation requires neural representations that encode environmental boundaries relative to the animal\&apos;s position and orientation. In the retrosplenial cortex ({RSC}), egocentric boundary cells ({EBCs}) respond when boundaries occupy specific angles and distances relative to the animal. Previous research has not compared computational properties of the response to boundary cues in egocentric coordinates (i.e. receptive fields ({RF})). We systematically compare a broad family of egocentric ({RF}) parameterizations to identify the computational strucuture that best account for {RSC} {EBC} responses. Using 174 {EBCs} pooled from two published datasets, we fit multiple models to spike data derived from freely moving rats in square arenas. These {RF} models included isotropic and elliptical 2D Gaussians, angle-distance Gaussians, angle-only and distance-only Gaussians, angle-bounded distance Gaussians, and difference-of-Gaussians ({DoG}).Extending the input from the nearest boundary point to include multiple visible boundaries points via ray tracing improved model evidence for nearly all {RF} families, and allowing inhibitory (negative-gain) {RFs} revealed a subset of neurons (13.8\%) better modeled by anti-{EBC} tuning.The angle-distance Gaussian model achieved the best median information criteria ({AIC}/{BIC}) across neurons, but its advantage was not statistically significant over the elliptical 2D and angle-bounded distance Gaussian models. Results suggest that the historically favored angle-distance Gaussian model {RF} shape remains a robust approximation for {EBC} tuning, though alternative parameterizations can capture comparable variance.Together, this study establishes a unified quantitative framework for evaluating models of egocentric boundary coding, highlighting the need for more comprehensive models of {RF} geometry in understanding egocentric spatial representations.},
	publisher = {{SSRN}},
	author = {Fang, Jiarui and {LaChance}, Patrick  A. and Hasselmo, Michael  E.},
	urldate = {2026-03-17},
	date = {2026},
}

@misc{robinson_how_2025,
	title = {How does the response of egocentric boundary cells depend upon the coordinate system of environmental features?},
	rights = {© 2025, Posted by Cold Spring Harbor Laboratory. The copyright holder for this pre-print is the author. All rights reserved. The material may not be redistributed, re-used or adapted without the author's permission.},
	url = {https://www.biorxiv.org/content/10.1101/2025.02.03.636060v2},
	doi = {10.1101/2025.02.03.636060},
	abstract = {Neurons in the retrosplenial ({RSC}) (Alexander et al 2020a, {LaChance} \& Hasselmo 2024) and postrhinal cortex ({POR}) respond to environmental boundaries and configurations using egocentric coordinates relative to an animal’s current position. Neurons in these structures and adjacent structures also respond to spatial dimensions of self-motion such as running velocity (Carstensen et al 2021, Robinson et al 2023). Experimental and modeling data suggest that these responses could be essential for guiding behaviors such as obstacle avoidance and goal-directed navigation (Erdem \& Hasselmo 2012, Erdem \& Hasselmo 2014). However, these findings still leave the unanswered question: What specific features, and in what coordinate frames, drive these egocentric neural responses? Here we present models of the potential circuit mechanisms generating egocentric responses in {RSC}. One model posits that neurons encode internal representations of barriers in head-centered coordinates, defined by distance and angle, which are modulated by running velocity to enable trajectory planning and obstacle avoidance. We contrast this with a complementary hypothesis in which neurons respond to retinotopic features—such as the top, bottom, or edges of walls, which may serve as precursors to head-centered representations. Additional hypotheses include trajectory-based forward scanning (e.g., ray tracing) for barrier detection or comparing optic flow across the visual field. These hypotheses generate complementary modeling predictions about how changes in environmental parameters could alter the neural responses of egocentric boundary cells that are presented here.},
	publisher = {{bioRxiv}},
	author = {Robinson, Jennifer C. and {LaChance}, Patrick A. and Malmberg, Samantha L. and Patel, Mahir and Gross, Elaina and Everett, Danielle E. and Sankaranarayanan, Shruthi and Fang, Jiarui and Hasselmo, Michael E.},
	urldate = {2026-06-19},
	date = {2025-09-08},
	langid = {english},
	note = {{ISSN}: 2692-8205
Pages: 2025.02.03.636060
Section: New Results},
	file = {Full Text PDF:C\:\\Users\\FangJ\\Zotero\\storage\\Z5SZP5N7\\Robinson 等 - 2025 - How does the response of egocentric boundary cells depend upon the coordinate system of environmenta.pdf:application/pdf},
}

@article{robinson_trajectory_2026,
	title = {Trajectory scanning as a predictive coding mechanism for goal-directed navigation, obstacle avoidance and episodic memory},
	volume = {381},
	issn = {0962-8436},
	url = {https://doi.org/10.1098/rstb.2025.0251},
	doi = {10.1098/rstb.2025.0251},
	abstract = {Planning of future trajectories through the environment may rely on our capacity to encode and recall episodic memories that include spatial representations. Here, we describe potential mechanisms for behaviour based on episodic memory that would use neural trajectory scanning to explore and select trajectories towards remembered goal locations. This model is consistent with rodent neurophysiological data recorded in the medial entorhinal cortex that demonstrated alternating left–right scans of space and data recorded in the hippocampus of place cell firing that showed alternating scans, or scans directed towards a goal location. In a related model, sequential activation of different directions along trajectories would allow encoding and retrieval of complex sequences of vectors that correspond to episodic memories of events at a specific time and place. Trajectory scanning may also detect and avoid potential collisions with representations of visible or remembered objects and barriers in allocentric or egocentric reference frameworks to plan trajectories. Moreover, the same trajectory scanning in egocentric space could generate egocentric neural responses such as egocentric boundary cells and egocentric bearing cells consistent with recent human imaging experiments. Together, these theoretical mechanisms provide a predictive coding framework linking allocentric navigation, episodic memory retrieval, and egocentric obstacle representations.This article is part of the theme issue ‘The role of hippocampal predictions in cognition: bridging perception and memory’.},
	pages = {20250251},
	number = {1954},
	journaltitle = {Philosophical Transactions of the Royal Society B: Biological Sciences},
	shortjournal = {Philos Trans R Soc Lond B Biol Sci},
	author = {Robinson, Jennifer C. and {LaChance}, Patrick A. and Malmberg, Samantha and Fang, Jiarui and Sankaranarayanan, Shruthi and Stern, Chantal E. and Hasselmo, Michael E.},
	urldate = {2026-07-09},
	date = {2026-07-09},
	file = {Full Text PDF:C\:\\Users\\FangJ\\Zotero\\storage\\8L8HEQW9\\Robinson 等 - 2026 - Trajectory scanning as a predictive coding mechanism for goal-directed navigation, obstacle avoidanc.pdf:application/pdf;Snapshot:C\:\\Users\\FangJ\\Zotero\\storage\\BWXT73G8\\rstb.2025.html:text/html},
}
